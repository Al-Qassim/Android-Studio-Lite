## This file is gitignored. Copy the keys you need into your local.properties.

sdk.dir=/path/to/Android/sdk

# GitHub OAuth App client id (public; not a secret). Enable Device Flow on the app.
# Do not put client_secret here — device flow keeps the secret out of the APK.
# Read into BuildConfig by :feature:auth:data (see project/architecture.md).
github.oauth.clientId=
